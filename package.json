{
  "name": "aster",
  "private": true,
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "generate-routes": "tsr generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply aster-db",
    "gen:openui": "npx @openuidev/cli@latest generate ./src/components/openui/library.tsx --out ./src/lib/openui/component-prompt.txt",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "ui": "pnpm dlx shadcn@latest",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "postinstall": "pnpm run cf-typegen"
  },
  "dependencies": {
